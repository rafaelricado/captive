<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dispositivo <%= mac %> &mdash; Captive Portal</title>
  <%- include('_head') %>
</head>
<body>
  <%- include('_nav', { page: pageObj }) %>

  <main class="container">
    <div style="margin-bottom:16px">
      <a href="/admin/devices" style="font-size:.875rem;color:#6b7280">&larr; Voltar para dispositivos</a>
    </div>

    <h2 class="page-title">
      <span style="font-family:monospace"><%= mac %></span>
      <% if (hostname !== mac) { %>
        <span style="font-size:1rem;font-weight:400;color:#6b7280;margin-left:8px">&mdash; <%= hostname %></span>
      <% } %>
    </h2>

    <p class="meta"><%= entries.length %> combinação(ões) IP encontrada(s)</p>

    <% if (entries.length === 0) { %>
      <p style="color:#9ca3af">Nenhum registro.</p>
    <% } else { %>
      <div class="timeline">
        <% entries.forEach(e => { %>
          <div class="timeline-entry">
            <div class="timeline-ip"><%= e.ip_address %></div>
            <% if (e.hostname && e.hostname !== '—') { %>
              <div class="timeline-host"><%= e.hostname %></div>
            <% } %>
            <div class="timeline-date">
              Primeiro: <%= e.first_seen %> &mdash; Último: <%= e.last_seen %>
            </div>
            <div class="timeline-date" style="color:#9ca3af"><%= e.router_name %></div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

  <%- include('_footer') %>
</body>
</html>
