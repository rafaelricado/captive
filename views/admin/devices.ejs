<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dispositivos &mdash; Captive Portal</title>
  <%- include('_head') %>
</head>
<body>
  <%- include('_nav', { page: pageObj }) %>

  <main class="container">
    <h2 class="page-title">Histórico de Dispositivos</h2>

    <p class="meta"><%= total %> dispositivo(s) único(s) no histórico</p>

    <form method="GET" action="/admin/devices" style="margin-bottom:16px;display:flex;gap:8px">
      <input type="text" name="q" value="<%= q %>" placeholder="Buscar por MAC, IP ou hostname..."
             style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:.875rem;flex:1;max-width:380px">
      <button type="submit" class="btn-outline" style="padding:8px 18px">Buscar</button>
      <% if (q) { %>
        <a href="/admin/devices" class="btn-outline" style="padding:8px 18px">Limpar</a>
      <% } %>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>MAC</th>
            <th>Hostname</th>
            <th>IPs usados</th>
            <th>Primeiro acesso</th>
            <th>Último acesso</th>
            <th>Roteador</th>
          </tr>
        </thead>
        <tbody>
          <% if (devices.length === 0) { %>
            <tr><td colspan="6" style="text-align:center;color:#9ca3af">Nenhum dispositivo encontrado.</td></tr>
          <% } %>
          <% devices.forEach(d => { %>
            <tr>
              <td><a href="/admin/devices/<%= d.mac_address %>" style="font-family:monospace;font-size:.85rem"><%= d.mac_address %></a></td>
              <td><%= d.hostname %></td>
              <td style="text-align:center"><%= d.ip_count %></td>
              <td style="font-size:.8rem;color:#6b7280"><%= d.first_seen %></td>
              <td style="font-size:.8rem;color:#6b7280"><%= d.last_seen %></td>
              <td><%= d.router_name %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="pagination">
      <% if (page > 0) { %>
        <a href="/admin/devices?page=<%= page - 1 %>&q=<%= encodeURIComponent(q) %>">&larr; Anterior</a>
      <% } %>
      <span class="current">Página <%= pageLabel %></span>
      <% if (page + 1 < totalPages) { %>
        <a href="/admin/devices?page=<%= page + 1 %>&q=<%= encodeURIComponent(q) %>">Próxima &rarr;</a>
      <% } %>
    </div>
  </main>

  <%- include('_footer') %>
</body>
</html>
