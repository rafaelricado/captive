<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: sans-serif; background: #f0f4f8; color: #1f2937; }

  /* ── Nav ──────────────────────────────────────────────────────────── */
  nav {
    background: #0d4e8b;
    padding: 0 32px;
    display: flex;
    align-items: center;
    position: relative;
    min-height: 52px;
  }
  nav .brand {
    color: #fff; font-weight: 700; font-size: 1rem;
    padding: 14px 0; margin-right: 20px; white-space: nowrap; flex-shrink: 0;
  }
  nav .nav-links {
    display: flex; align-items: center; gap: 0; flex: 1;
  }
  nav .nav-links a {
    color: rgba(255,255,255,.75); text-decoration: none;
    padding: 14px 14px; font-size: .875rem; white-space: nowrap;
    transition: color .15s;
  }
  nav .nav-links a:hover, nav .nav-links a.active { color: #fff; }
  nav .nav-links .spacer { flex: 1; }
  nav .nav-links .nav-home-link {
    color: rgba(255,255,255,.6); text-decoration: none;
    padding: 14px 16px 14px 0; font-size: .8rem; white-space: nowrap;
    border-right: 1px solid rgba(255,255,255,.2);
    margin-right: 4px; transition: color .15s;
  }
  nav .nav-links .nav-home-link:hover { color: #fff; }
  nav .nav-links .nav-section {
    color: rgba(255,255,255,.4); font-size: .7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
    padding: 0 8px; white-space: nowrap;
  }
  nav .nav-links form button {
    background: none; border: 1px solid rgba(255,255,255,.4);
    color: rgba(255,255,255,.8); padding: 6px 14px;
    border-radius: 6px; cursor: pointer; font-size: .8rem;
    transition: all .15s; white-space: nowrap;
  }
  nav .nav-links form button:hover { background: rgba(255,255,255,.1); color: #fff; }

  /* Hamburger button */
  nav .hamburger {
    display: none;
    background: none; border: none; cursor: pointer;
    color: #fff; font-size: 1.5rem; padding: 6px 8px;
    margin-left: auto; line-height: 1;
  }

  /* ── Container ────────────────────────────────────────────────────── */
  .container { max-width: 100%; padding: 28px 48px; }
  .page-title { font-size: 1.4rem; font-weight: 700; color: #0d4e8b; margin-bottom: 24px; }

  /* ── Cards ────────────────────────────────────────────────────────── */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }
  .card {
    background: #fff; border-radius: 12px;
    box-shadow: 0 1px 6px rgba(0,0,0,.08);
    padding: 24px 20px; text-align: center;
  }
  .card-green { border-top: 4px solid #16a34a; }
  .card-value { font-size: 2.2rem; font-weight: 700; color: #0d4e8b; line-height: 1; }
  .card-green .card-value { color: #16a34a; }
  .card-label { font-size: .8rem; color: #6b7280; margin-top: 6px; }

  /* ── Quick links ──────────────────────────────────────────────────── */
  .quick-links { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-outline {
    display: inline-block;
    border: 1px solid #0d4e8b; color: #0d4e8b;
    padding: 8px 18px; border-radius: 8px;
    text-decoration: none; font-size: .875rem;
    transition: all .15s;
  }
  .btn-outline:hover { background: #0d4e8b; color: #fff; }

  /* ── Table ────────────────────────────────────────────────────────── */
  .table-wrap { overflow-x: auto; border-radius: 12px; }
  table {
    width: 100%; border-collapse: collapse;
    background: #fff; border-radius: 12px;
    box-shadow: 0 1px 6px rgba(0,0,0,.08);
    font-size: .875rem;
    overflow: hidden;
  }
  thead { background: #0d4e8b; color: #fff; }
  th { padding: 12px 14px; text-align: left; font-weight: 600; white-space: nowrap; }
  td { padding: 11px 14px; border-bottom: 1px solid #f3f4f6; white-space: nowrap; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #f9fafb; }
  .badge {
    display: inline-block; padding: 2px 10px;
    border-radius: 99px; font-size: .75rem; font-weight: 600;
  }
  .badge-green  { background: #dcfce7; color: #16a34a; }
  .badge-gray   { background: #f3f4f6; color: #6b7280; }
  .badge-orange { background: #fef3c7; color: #d97706; }
  .badge-red    { background: #fee2e2; color: #dc2626; }

  /* ── Pagination ───────────────────────────────────────────────────── */
  .meta { color: #6b7280; font-size: .8rem; margin-bottom: 12px; }
  .pagination { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; }
  .pagination a, .pagination span {
    padding: 6px 14px; border-radius: 6px;
    font-size: .875rem; text-decoration: none;
    border: 1px solid #d1d5db; color: #374151;
  }
  .pagination a:hover { background: #e5e7eb; }
  .pagination .current { background: #0d4e8b; color: #fff; border-color: #0d4e8b; }

  /* ── Footer ───────────────────────────────────────────────────────── */
  footer { text-align: center; font-size: .75rem; color: #9ca3af; padding: 24px; }

  /* ── Breakpoints ──────────────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .container { padding: 24px 32px; }
    nav { padding: 0 24px; }
  }

  @media (max-width: 900px) {
    .container { padding: 20px 20px; }
    nav { padding: 0 16px; }
    nav .nav-links a { padding: 14px 10px; font-size: .82rem; }
  }

  @media (max-width: 768px) {
    nav .hamburger { display: block; }

    nav .nav-links {
      display: none;
      position: absolute; top: 100%; left: 0; right: 0;
      background: #0b4070;
      flex-direction: column; align-items: flex-start;
      padding: 8px 0; z-index: 100;
      box-shadow: 0 4px 12px rgba(0,0,0,.25);
    }
    nav .nav-links.open { display: flex; }

    nav .nav-links a {
      width: 100%; padding: 12px 20px; font-size: .9rem;
      border-bottom: 1px solid rgba(255,255,255,.06);
    }
    nav .nav-links .nav-section {
      border-left: none; padding: 10px 20px 4px;
      border-top: 1px solid rgba(255,255,255,.12); width: 100%;
    }
    nav .nav-links .spacer { display: none; }
    nav .nav-links form {
      width: 100%; padding: 10px 20px 14px;
      border-top: 1px solid rgba(255,255,255,.12);
    }
    nav .nav-links form button { width: 100%; text-align: center; }

    .container { padding: 16px 14px; }
    .cards { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
    .card { padding: 18px 14px; }
    .card-value { font-size: 1.8rem; }
    th, td { padding: 10px 10px; font-size: .8rem; }
  }

  @media (max-width: 480px) {
    nav .brand { font-size: .9rem; }
    .page-title { font-size: 1.15rem; margin-bottom: 16px; }
    .cards { grid-template-columns: 1fr 1fr; }
    .btn-action { min-height: 40px; padding: 10px 16px !important; font-size: .85rem !important; }
  }

  /* ── #6 Sticky table headers ──────────────────────────────────────── */
  .table-wrap { -webkit-overflow-scrolling: touch; }
  .table-wrap thead th { position: sticky; top: 0; background: #0d4e8b; z-index: 2; }

  /* ── #4 Sortable columns ──────────────────────────────────────────── */
  th.th-sortable { cursor: pointer; user-select: none; }
  th.th-sortable::after { content: ' ⇅'; opacity: .4; font-size: .75em; }
  th.th-sortable.sort-asc::after  { content: ' ▲'; opacity: 1; }
  th.th-sortable.sort-desc::after { content: ' ▼'; opacity: 1; }

  /* ── #7 Toast notifications ───────────────────────────────────────── */
  .toast-container {
    position: fixed; bottom: 24px; right: 24px;
    display: flex; flex-direction: column; gap: 8px; z-index: 9999;
    pointer-events: none;
  }
  .toast {
    padding: 12px 20px; border-radius: 10px; font-size: .875rem; font-weight: 600;
    color: #fff; box-shadow: 0 4px 16px rgba(0,0,0,.18);
    opacity: 0; transform: translateY(12px);
    transition: opacity .25s, transform .25s;
    pointer-events: auto; max-width: 320px;
  }
  .toast.show { opacity: 1; transform: translateY(0); }
  .toast-success { background: #16a34a; }
  .toast-error   { background: #dc2626; }
  .toast-info    { background: #0d4e8b; }

  /* ── #9 Online badge ──────────────────────────────────────────────── */
  .dot-online {
    width: 8px; height: 8px; background: #16a34a; border-radius: 50%;
    display: inline-block; margin-right: 5px; vertical-align: middle;
    box-shadow: 0 0 0 2px #dcfce7;
  }

  /* ── #10 Device history timeline ─────────────────────────────────── */
  .timeline { padding: 8px 0 0 16px; }
  .timeline-entry {
    position: relative; padding: 0 0 24px 24px; border-left: 2px solid #e5e7eb;
  }
  .timeline-entry:last-child { border-left: 2px solid transparent; padding-bottom: 0; }
  .timeline-entry::before {
    content: ''; position: absolute; left: -7px; top: 4px;
    width: 12px; height: 12px; border-radius: 50%;
    background: #0d4e8b; border: 2px solid #fff; box-shadow: 0 0 0 2px #0d4e8b;
  }
  .timeline-ip   { font-family: monospace; font-weight: 700; font-size: .9rem; color: #0d4e8b; }
  .timeline-host { font-size: .8rem; color: #374151; margin-top: 1px; }
  .timeline-date { font-size: .75rem; color: #9ca3af; margin-top: 2px; }

  /* ── #3 Security alert banner ─────────────────────────────────────── */
  .alert-banner {
    background: #fefce8; border: 1px solid #fde047; border-radius: 10px;
    padding: 12px 18px; margin-bottom: 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    font-size: .875rem; color: #854d0e;
  }
  .alert-banner a { color: #92400e; font-weight: 700; text-decoration: underline; }

  /* ── Status filter tabs ───────────────────────────────────────────── */
  .filter-tabs { display: flex; gap: 4px; margin-bottom: 16px; flex-wrap: wrap; }
  .filter-tab {
    padding: 6px 16px; border-radius: 20px; font-size: .8rem; font-weight: 600;
    text-decoration: none; border: 1px solid #d1d5db; color: #6b7280; transition: all .15s;
  }
  .filter-tab:hover { border-color: #0d4e8b; color: #0d4e8b; }
  .filter-tab.active { background: #0d4e8b; color: #fff; border-color: #0d4e8b; }
</style>
