<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contas Tasy &mdash; Painel Admin</title>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <%- include('_head') %>
  <style>
    .card-aberto   { border-top: 4px solid #dc2626; }
    .card-pendente { border-top: 4px solid #d97706; }
    .card-faturado { border-top: 4px solid #16a34a; }
    .card-geral    { border-top: 4px solid #0d4e8b; }
    .card-glosa    { border-top: 4px solid #7c3aed; }
    .card-aberto   .card-value { color: #dc2626; }
    .card-pendente .card-value { color: #d97706; }
    .card-faturado .card-value { color: #16a34a; }
    .card-geral    .card-value { color: #0d4e8b; }
    .card-glosa    .card-value { color: #7c3aed; }
    .card-sub { font-size:.78rem; color:#6b7280; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .card-sub2 { font-size:.72rem; color:#9ca3af; margin-top:1px; }

    .badge-aberto   { background:#fee2e2; color:#dc2626; }
    .badge-pendente { background:#fef3c7; color:#d97706; }
    .badge-faturado { background:#d1fae5; color:#16a34a; }
    .badge-outro    { background:#f3f4f6; color:#6b7280; }
    .badge { display:inline-block; padding:2px 10px; border-radius:99px; font-size:.72rem; font-weight:700; white-space:nowrap; }
    .badge-cancelado { background:#fce7f3; color:#be185d; }
    .badge-prot-1 { background:#eff6ff; color:#1d4ed8; }
    .badge-prot-2 { background:#f0fdf4; color:#15803d; }
    .badge-prot-3 { background:#fff7ed; color:#c2410c; }
    .badge-prot-4 { background:#fef2f2; color:#b91c1c; }
    .badge-prot-5 { background:#f3f4f6; color:#6b7280; }

    .filter-bar {
      display:flex; align-items:center; gap:8px; flex-wrap:wrap;
      background:#fff; border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,.07);
      padding:12px 16px; margin-bottom:16px;
    }
    .filter-bar select, .filter-bar input[type="text"], .filter-bar input[type="date"] {
      padding:6px 10px; border:1px solid #d1d5db; border-radius:6px; font-size:.82rem; color:#1f2937; background:#f9fafb;
    }
    .btn-filter { padding:6px 14px; background:#0d4e8b; color:#fff; border:none; border-radius:6px; font-size:.82rem; cursor:pointer; font-weight:600; }
    .btn-clear  { font-size:.82rem; color:#6b7280; text-decoration:none; }
    .btn-clear:hover { color:#0d4e8b; }

    .toolbar { display:flex; align-items:center; justify-content:space-between; gap:8px; flex-wrap:wrap; margin-bottom:12px; }
    .toolbar-left  { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .toolbar-right { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .sync-info { font-size:.78rem; color:#9ca3af; }
    .btn-sync   { padding:6px 14px; background:#fff; color:#0d4e8b; border:1px solid #0d4e8b; border-radius:6px; font-size:.82rem; cursor:pointer; font-weight:600; transition:all .15s; }
    .btn-sync:hover    { background:#0d4e8b; color:#fff; }
    .btn-sync:disabled { opacity:.5; cursor:not-allowed; }
    .btn-export { padding:6px 14px; background:#fff; color:#374151; border:1px solid #d1d5db; border-radius:6px; font-size:.82rem; cursor:pointer; font-weight:600; text-decoration:none; display:inline-block; }
    .btn-export:hover { border-color:#0d4e8b; color:#0d4e8b; }

    .chart-wrap { background:#fff; border-radius:12px; box-shadow:0 1px 6px rgba(0,0,0,.08); padding:16px 24px; margin-bottom:24px; }
    .chart-title { font-size:.85rem; font-weight:600; color:#374151; margin-bottom:10px; }

    td.valor  { text-align:right; font-variant-numeric:tabular-nums; white-space:nowrap; }
    td.center { text-align:center; }
    .td-sub   { font-size:.73rem; color:#9ca3af; }
    .glosa-pct { font-size:.72rem; color:#7c3aed; font-weight:600; }

    @media (max-width:768px) {
      .filter-bar { flex-direction:column; align-items:flex-start; }
      .toolbar    { flex-direction:column; align-items:flex-start; }
    }
  </style>
</head>
<body>
  <%- include('_nav', { page: page }) %>

  <main class="container">
    <h2 class="page-title">Tasy &mdash; Contas de Paciente</h2>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:2px solid #e5e7eb;">
      <a href="/admin/tasy" style="padding:8px 18px;font-size:.85rem;font-weight:600;color:#0d4e8b;background:#fff;border:2px solid #e5e7eb;border-bottom-color:#fff;border-radius:6px 6px 0 0;text-decoration:none;margin-bottom:-2px;">Contas de Paciente</a>
      <a href="/admin/tasy/protocolos" style="padding:8px 18px;font-size:.85rem;font-weight:600;color:#6b7280;text-decoration:none;border-radius:6px 6px 0 0;border:2px solid transparent;border-bottom:none;margin-bottom:-2px;">Protocolo Convênio</a>
    </div>

    <!-- Cards de resumo (5 cards) -->
    <div class="cards" style="grid-template-columns:repeat(5,1fr);">
      <div class="card card-aberto">
        <div class="card-value"><%= cards.aberto.total.toLocaleString('pt-BR') %></div>
        <div class="card-label">Em Aberto</div>
        <div class="card-sub"><%= cards.aberto.valor %></div>
        <div class="card-sub2">Líq: <%= cards.aberto.liquido %></div>
      </div>
      <div class="card card-pendente">
        <div class="card-value"><%= cards.pendente.total.toLocaleString('pt-BR') %></div>
        <div class="card-label">Pend. Faturamento</div>
        <div class="card-sub"><%= cards.pendente.valor %></div>
        <div class="card-sub2">Líq: <%= cards.pendente.liquido %></div>
      </div>
      <div class="card card-faturado">
        <div class="card-value"><%= cards.faturado.total.toLocaleString('pt-BR') %></div>
        <div class="card-label">Faturadas</div>
        <div class="card-sub"><%= cards.faturado.valor %></div>
        <div class="card-sub2">Líq: <%= cards.faturado.liquido %></div>
      </div>
      <div class="card card-geral">
        <div class="card-value"><%= cards.geral.total.toLocaleString('pt-BR') %></div>
        <div class="card-label">Total Geral</div>
        <div class="card-sub"><%= cards.geral.valor %></div>
        <div class="card-sub2">Líq: <%= cards.geral.liquido %></div>
      </div>
      <div class="card card-glosa">
        <div class="card-value"><%= cards.glosa.mediaPerc %>%</div>
        <div class="card-label">Glosa Média</div>
        <div class="card-sub"><%= cards.glosa.valor %></div>
        <div class="card-sub2">total glosado</div>
      </div>
    </div>

    <!-- Gráfico de evolução mensal -->
    <div class="chart-wrap">
      <p class="chart-title">
        Contas por mês —
        <% if (filters.dtInicio || filters.dtFim) { %>período selecionado<% } else { %>últimos 12 meses<% } %>
        <% if (filters.status || filters.convenio || filters.setor || filters.tipo || filters.especialidade || filters.q) { %>
          <span style="font-weight:400;color:#9ca3af;">(filtros ativos)</span>
        <% } %>
      </p>
      <canvas id="tasy-chart" height="90"></canvas>
    </div>

    <!-- Filtros -->
    <form method="GET" action="/admin/tasy" class="filter-bar" id="filter-form">
      <input type="text" name="q" placeholder="Paciente / Nº atend. / Médico"
             value="<%= filters.q || '' %>" style="min-width:190px;">

      <select name="status">
        <option value="">Todos os status</option>
        <% ['aberto','pendente','faturado','outro'].forEach(s => { %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>>
            <%= s.charAt(0).toUpperCase() + s.slice(1) %>
          </option>
        <% }) %>
      </select>

      <select name="convenio">
        <option value="">Todos os convênios</option>
        <% convenios.forEach(c => { %>
          <option value="<%= c %>" <%= filters.convenio === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>

      <select name="tipo">
        <option value="">Todos os tipos</option>
        <% tipos.forEach(t => { %>
          <option value="<%= t %>" <%= filters.tipo === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>

      <select name="especialidade">
        <option value="">Todas as especialidades</option>
        <% especialidades.forEach(e => { %>
          <option value="<%= e %>" <%= filters.especialidade === e ? 'selected' : '' %>><%= e %></option>
        <% }) %>
      </select>

      <select name="setor">
        <option value="">Todos os setores</option>
        <% setores.forEach(s => { %>
          <option value="<%= s %>" <%= filters.setor === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>

      <input type="date" name="dtInicio" value="<%= filters.dtInicio || '' %>" title="Data entrada de">
      <input type="date" name="dtFim"    value="<%= filters.dtFim    || '' %>" title="Data entrada até">

      <label style="display:flex;align-items:center;gap:5px;font-size:.82rem;color:#374151;white-space:nowrap;cursor:pointer;">
        <input type="checkbox" name="zeradas" value="1" <%= filters.zeradas === '1' ? 'checked' : '' %>>
        Somente zeradas
      </label>
      <label style="display:flex;align-items:center;gap:5px;font-size:.82rem;color:#374151;white-space:nowrap;cursor:pointer;">
        <input type="checkbox" name="cancelados" value="1" <%= filters.cancelados === '1' ? 'checked' : '' %>>
        Canceladas
      </label>

      <button type="submit" class="btn-filter">Filtrar</button>
      <a href="/admin/tasy" class="btn-clear">Limpar</a>
    </form>

    <!-- Toolbar -->
    <div class="toolbar">
      <div class="toolbar-left">
        <span style="font-size:.85rem;color:#374151;">
          <strong><%= total.toLocaleString('pt-BR') %></strong> conta<%= total !== 1 ? 's' : '' %>
        </span>
        <% if (lastSync) { %>
          <span class="sync-info">Última sincronização: <%= lastSync %></span>
        <% } else { %>
          <span class="sync-info" style="color:#dc2626;">Nenhuma sincronização realizada</span>
        <% } %>
      </div>
      <div class="toolbar-right">
        <button class="btn-sync" id="btn-sync">&#8635; Sincronizar agora</button>
        <a href="/admin/tasy/export?<%= new URLSearchParams(filters).toString() %>"
           class="btn-export">&#8595; Exportar CSV</a>
      </div>
    </div>

    <!-- Tabela -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nº Atendimento</th>
            <th>Paciente / CPF</th>
            <th>Convênio / Plano</th>
            <th>Tipo / Especialidade</th>
            <th>Médico</th>
            <th>Status</th>
            <th style="text-align:right;">Faturado</th>
            <th style="text-align:right;">Glosa</th>
            <th style="text-align:right;">Líquido</th>
            <th>Entrada</th>
            <th>Faturamento</th>
            <th>Status Protocolo</th>
          </tr>
        </thead>
        <tbody>
          <% if (contas.length === 0) { %>
            <tr><td colspan="12" style="text-align:center;color:#9ca3af;padding:32px;">
              Nenhuma conta encontrada.
              <% if (!lastSync) { %>Realize a sincronização com o Tasy para importar os dados.<% } %>
            </td></tr>
          <% } else { %>
            <% contas.forEach(c => { %>
              <tr>
                <td><code style="font-size:.8rem;"><%= c.nr_atendimento %></code></td>
                <td>
                  <%= c.nm_paciente %>
                  <% if (c.cd_pessoa_fisica) { %>
                    <div class="td-sub"><%= c.cd_pessoa_fisica %></div>
                  <% } %>
                </td>
                <td style="font-size:.82rem;">
                  <%= c.ds_convenio %>
                  <% if (c.ds_plano && c.ds_plano !== c.ds_convenio) { %>
                    <div class="td-sub"><%= c.ds_plano %></div>
                  <% } %>
                </td>
                <td style="font-size:.82rem;">
                  <%= c.ds_tipo_atendimento %>
                  <% if (c.ds_especialidade) { %>
                    <div class="td-sub"><%= c.ds_especialidade %></div>
                  <% } %>
                </td>
                <td style="font-size:.82rem;"><%= c.nm_medico %></td>
                <td class="center">
                  <% if (c.ie_cancelamento) { %>
                    <span class="badge badge-cancelado">Cancelada</span>
                  <% } else { %>
                    <span class="badge badge-<%= c.status_categoria %>">
                      <%= c.status_categoria === 'aberto'   ? 'Em Aberto' :
                          c.status_categoria === 'pendente' ? 'Pendente'  :
                          c.status_categoria === 'faturado' ? 'Faturado'  : 'Outro' %>
                    </span>
                  <% } %>
                </td>
                <td class="valor"><%= c.vl_conta %></td>
                <td class="valor">
                  <%= c.vl_glosa %>
                  <% if (Number(c.pr_glosa) > 0) { %>
                    <div class="glosa-pct"><%= c.pr_glosa %>%</div>
                  <% } %>
                </td>
                <td class="valor"><%= c.vl_liquido %></td>
                <td style="font-size:.82rem;"><%= c.dt_entrada %></td>
                <td style="font-size:.82rem;"><%= c.dt_faturamento %></td>
                <td class="center">
                  <% if (c.ie_status_protocolo) { %>
                    <span class="badge badge-prot-<%= c.ie_status_protocolo %>"><%= c.ds_status_protocolo %></span>
                    <% if (c.nr_seq_protocolo) { %>
                      <div class="td-sub">#<%= c.nr_seq_protocolo %></div>
                    <% } %>
                  <% } else { %>
                    <span style="color:#d1d5db;">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Paginação -->
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (pageNum > 0) { %>
          <a href="/admin/tasy?<%= new URLSearchParams({...filters, page: pageNum - 1}).toString() %>">&laquo; Anterior</a>
        <% } %>
        <span>Página <%= pageNum + 1 %> de <%= totalPages %></span>
        <% if (pageNum < totalPages - 1) { %>
          <a href="/admin/tasy?<%= new URLSearchParams({...filters, page: pageNum + 1}).toString() %>">Próxima &raquo;</a>
        <% } %>
      </div>
    <% } %>
  </main>

  <%- include('_footer') %>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script>
  (function () {
    const chartData = <%- chartData %>;

    if (chartData && chartData.length > 0) {
      const meses = [...new Set(chartData.map(r => r.mes))].sort();
      const cats = { aberto: [], pendente: [], faturado: [] };

      meses.forEach(mes => {
        ['aberto', 'pendente', 'faturado'].forEach(cat => {
          const row = chartData.find(r => r.mes === mes && r.status_categoria === cat);
          cats[cat].push(row ? Number(row.total) : 0);
        });
      });

      const labels = meses.map(m => {
        const [y, mo] = m.split('-');
        return new Date(Number(y), Number(mo) - 1).toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
      });

      new Chart(document.getElementById('tasy-chart').getContext('2d'), {
        type: 'bar',
        data: {
          labels,
          datasets: [
            { label: 'Em Aberto', data: cats.aberto,   backgroundColor: 'rgba(220,38,38,.75)' },
            { label: 'Pendente',  data: cats.pendente, backgroundColor: 'rgba(217,119,6,.75)'  },
            { label: 'Faturado',  data: cats.faturado, backgroundColor: 'rgba(22,163,74,.75)'  },
          ]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { position: 'top' },
            tooltip: { callbacks: { label: c => ` ${c.dataset.label}: ${Number(c.raw).toLocaleString('pt-BR')} contas` } }
          },
          scales: { x: { stacked: false }, y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
      });
    }

    // Sincronização manual
    const btnSync = document.getElementById('btn-sync');
    const csrf    = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

    btnSync.addEventListener('click', function () {
      if (!confirm('Sincronizar contas do Tasy agora?')) return;
      btnSync.disabled = true;
      btnSync.textContent = 'Sincronizando...';
      fetch('/admin/tasy/sync', {
        method: 'POST',
        headers: { 'X-CSRF-Token': csrf, 'Content-Type': 'application/json' },
        body: JSON.stringify({})
      })
        .then(r => r.json())
        .then(d => {
          if (d.ok) { alert(`Sincronização concluída: ${d.count.toLocaleString('pt-BR')} contas.`); location.reload(); }
          else alert('Erro: ' + (d.error || 'desconhecido'));
        })
        .catch(() => alert('Falha na requisição.'))
        .finally(() => { btnSync.disabled = false; btnSync.textContent = '↻ Sincronizar agora'; });
    });
  })();
  </script>
</body>
</html>
